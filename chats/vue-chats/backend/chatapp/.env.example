# Server
SOCKET_PORT=3001
NODE_ENV=development

# Frontend allowed origin
FRONT_ORIGIN=http://localhost:5173

# Optional auth key if you implement JWT verification
JWT_SECRET=change-me

# Model selection
USE_SQL_MODEL=false
MAX_ACTIVE_CONVERSATIONS=3

# Main DB
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=secret
DB_NAME=chatdb

# Optional dedicated DBs
TIPIFICACIONES_DB_HOST=
TIPIFICACIONES_DB_PORT=3306
TIPIFICACIONES_DB_USER=
TIPIFICACIONES_DB_PASSWORD=
TIPIFICACIONES_DB_NAME=

USUARIOSB_DB_HOST=
USUARIOSB_DB_PORT=3306
USUARIOSB_DB_USER=
USUARIOSB_DB_PASSWORD=
USUARIOSB_DB_NAME=

COLAS_DB_HOST=
COLAS_DB_PORT=3306
COLAS_DB_USER=
COLAS_DB_PASSWORD=
COLAS_DB_NAME=

# Redis
REDIS_ENABLED=true
REDIS_URL=redis://127.0.0.1:6379

# Supabase Storage (imágenes, documentos, audio del chat)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Alternativa: SUPABASE_PROJECT_REF=YOUR_PROJECT_REF
SUPABASE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=chat-media
